{
  "name": "dbschemix/pdo",
  "description": "dbschemix: database migration pdo",
  "type": "library",
  "license": "MIT",
  "authors": [
    {
      "name": "Dmitriy Krivopalov",
      "email": "dimarik82@gmail.com"
    }
  ],
  "support": {
    "issues": "https://github.com/dbschemix/pdo/issues",
    "source": "https://github.com/dbschemix/pdo"
  },
  "require": {
    "php": "^8.3",
    "ext-pdo": "*",
    "dbschemix/core": "^1.0"
  },
  "require-dev": {
    "buggregator/trap": "^1.15",
    "infection/infection": "^0.32.4",
    "php-di/php-di": "^7.1",
    "phpstan/phpstan": "^2.0",
    "phpunit/phpunit": "^12.5",
    "rector/rector": "^2.0",
    "roave/security-advisories": "dev-latest",
    "slevomat/coding-standard": "^8.7",
    "squizlabs/php_codesniffer": "^3.7",
    "vimeo/psalm": "^6.13"
  },
  "autoload": {
    "psr-4": {
      "dbschemix\\pdo\\": "src",
      "dbschemix\\pdo\\example\\": "example"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "dbschemix\\pdo\\tests\\": "tests"
    }
  },
  "config": {
    "allow-plugins": {
      "dealerdirect/phpcodesniffer-composer-installer": true,
      "infection/extension-installer": true
    },
    "sort-packages": true
  },
  "repositories": [
    {
      "type": "vcs",
      "url": "https://github.com/dbschemix/core"
    }
  ],
  "scripts": {
    "fix": [
      "@phpcbf",
      "@rector"
    ],
    "check": [
      "@phpcs",
      "@psalm",
      "@phpstan"
    ],
    "phpcbf": "vendor/bin/phpcbf",
    "rector": "vendor/bin/rector",
    "phpcs": "vendor/bin/phpcs",
    "psalm": "vendor/bin/psalm --show-info --no-diff --no-cache",
    "phpstan": "vendor/bin/phpstan analyze -c phpstan.neon"
  },
  "prefer-stable": true
}
